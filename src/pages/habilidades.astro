---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { certificaciones } from '../data/certificaciones.js';
import '../styles/habilidades.css';
import '../styles/global.css';

const totalHoras = certificaciones.reduce((sum, cert) => sum + (cert.horas || 0), 0);
const completadas = certificaciones.filter(cert => (cert.completado || 0) === 100).length;
const tasaFinal = certificaciones.length > 0 ? Math.round((completadas / certificaciones.length) * 100) : 0;
---

<Layout title="Habilidades - Uziel Sánchez Marín">
  <Header />

  <!-- Floating Navigation Menu -->
  <div class="floating-nav" id="floatingNav">
    <button class="floating-nav-toggle" id="floatingNavToggle">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
    <div class="floating-nav-menu" id="floatingNavMenu">
      <a href="#formacion" class="floating-nav-item">
        <span class="floating-nav-icon">🎓</span>
        <span class="floating-nav-text">Formación</span>
      </a>
      <a href="#certificaciones" class="floating-nav-item">
        <span class="floating-nav-icon">📜</span>
        <span class="floating-nav-text">Certificaciones</span>
      </a>
      <a href="#timeline" class="floating-nav-item">
        <span class="floating-nav-icon">⏳</span>
        <span class="floating-nav-text">Timeline</span>
      </a>
      <a href="#conocimientos" class="floating-nav-item">
        <span class="floating-nav-icon">💡</span>
        <span class="floating-nav-text">Conocimientos</span>
      </a>
      <a href="#aptitudes" class="floating-nav-item">
        <span class="floating-nav-icon">⭐</span>
        <span class="floating-nav-text">Aptitudes</span>
      </a>
      <a href="#tecnologias" class="floating-nav-item">
        <span class="floating-nav-icon">⚙️</span>
        <span class="floating-nav-text">Tecnologías</span>
      </a>
      <a href="#idiomas" class="floating-nav-item">
        <span class="floating-nav-icon">🌍</span>
        <span class="floating-nav-text">Idiomas</span>
      </a>
    </div>
  </div>

  <!-- FONDO TECNOLÓGICO ÉPICO -->
  <div class="tech-background" id="techBackground">
    <!-- Grid tecnológico -->
    <div class="tech-grid"></div>
    
    <!-- Placa de circuitos -->
    <div class="circuit-board" id="circuitBoard"></div>
    
    <!-- Código binario (Matrix) -->
    <div id="binaryContainer"></div>
    
    <!-- Hologramas flotantes -->
    <div class="hologram" style="top: 15%; left: 10%;"></div>
    <div class="hologram" style="bottom: 20%; right: 15%;"></div>
    
    <!-- Terminales de código -->
    <div class="code-terminal" style="top: 10%; right: 5%;">
      <div class="code-line">const developer = &#123;</div>
      <div class="code-line">  skills: ['Java', 'JS', 'Python'],</div>
      <div class="code-line">  passion: 'technology',</div>
      <div class="code-line">&#125;;<span class="cursor-blink">_</span></div>
    </div>
    
    <div class="code-terminal" style="bottom: 15%; left: 8%;">
      <div class="code-line">function innovate() &#123;</div>
      <div class="code-line">  return 'Excellence';</div>
      <div class="code-line">&#125;<span class="cursor-blink">_</span></div>
    </div>
    
    <!-- Íconos tecnológicos flotantes -->
    <div class="tech-icon" style="top: 25%; left: 5%; color: #3b82f6;">💻</div>
    <div class="tech-icon" style="top: 40%; right: 10%; color: #ef4444;">🚀</div>
    <div class="tech-icon" style="bottom: 30%; left: 15%; color: #fbbf24;">⚡</div>
    <div class="tech-icon" style="top: 60%; right: 20%; color: #10b981;">🔧</div>
    <div class="tech-icon" style="bottom: 45%; left: 25%; color: #8b5cf6;">🎯</div>
    <div class="tech-icon" style="top: 70%; right: 5%; color: #f59e0b;">🌐</div>
    
    <!-- Partículas de datos -->
    <div id="dataParticlesContainer"></div>
    
    <!-- Hexágonos -->
    <div id="hexContainer"></div>
    
    <!-- Escáneres láser -->
    <div class="laser-scan" style="animation-delay: 0s;"></div>
    <div class="laser-scan" style="animation-delay: 4s;"></div>
    
    <!-- Ondas de radar -->
    <div class="radar-wave" style="top: 20%; left: 20%;"></div>
    <div class="radar-wave" style="bottom: 25%; right: 25%; animation-delay: 2s;"></div>
    
    <!-- Textos glitch -->
    <div class="glitch-text" style="top: 35%; left: 50%; transform: translateX(-50%);">
      DEVELOPER
    </div>
    <div class="glitch-text" style="bottom: 40%; right: 8%;">
      INNOVATE
    </div>
  </div>

  <div id="particles-bg" class="particles-container"></div>

  <main class="main-content">
    <section id="formacion" class="section-formacion">
      <div class="container-max">
        <h2 class="section-title gsap-title">Formación Académica</h2>
        <ul class="academic-list gsap-list">
          <li class="academic-item">
            <strong class="text-highlight">Ingeniería en Sistemas:</strong> Universidad Bancaria de México (2021-2025)
          </li>
          <li class="academic-item">
            <strong class="text-highlight">Técnico en Programación:</strong> Universidad Bancaria de México (2016-2019)
          </li>
        </ul>
      </div>
    </section>

    
   <section id="certificaciones" class="section-certificaciones">
      <div class="container-max-lg">
        <h2 class="section-title gsap-title">Certificaciones</h2>

        <div class="stats-grid gsap-stats">
          <div class="stat-card">
            <p class="stat-number" data-target={certificaciones.length}>0</p>
            <p class="stat-label">Certificaciones</p>
          </div>
          <div class="stat-card">
            <p class="stat-number" data-target={totalHoras}>0</p>
            <p class="stat-label">Horas de Estudio</p>
          </div>
          <div class="stat-card">
            <p class="stat-number" data-target={tasaFinal}>0</p>
            <p class="stat-label">Tasa de Finalización</p>
          </div>
        </div>

        <div class="search-container">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="🔍 Buscar certificaciones..." 
            class="search-input"
          />
        </div>

        <div class="filters-container gsap-filters">
          <button class="filter-btn active" data-filter="all" id="habilidades-filter-all">Todas</button>
          <button class="filter-btn" data-filter="programming" id="habilidades-filter-programming">Programación</button>
          <button class="filter-btn" data-filter="database" id="habilidades-filter-database">Base de Datos</button>
          <button class="filter-btn" data-filter="marketing" id="habilidades-filter-marketing">Marketing</button>
          <button class="filter-btn" data-filter="agile" id="habilidades-filter-agile">Metodologías Ágiles</button>
          <button class="filter-btn" data-filter="frameworks" id="habilidades-filter-frameworks">Frameworks</button>
          <button class="filter-btn" data-filter="cloud" id="habilidades-filter-cloud">Nube</button>
          <button class="filter-btn" data-filter="tools" id="habilidades-filter-tools">Herramientas</button>
          <button class="filter-btn" data-filter="leadership" id="habilidades-filter-leadership">Liderazgo</button>
          <button class="filter-btn" data-filter="ai" id="habilidades-filter-ai">IA/ML</button>
          <button class="filter-btn" data-filter="language" id="habilidades-filter-language">Idiomas</button>
          <button class="filter-btn" data-filter="architecture" id="habilidades-filter-architecture">Arquitectura</button>
        </div>

        <div id="certificatesGrid" class="certificates-grid gsap-certificates">
          {certificaciones.map((cert) => (
            cert.url ? (
              <a 
                href={cert.url} 
                target="_blank" 
                class="certificate-card"
                data-category={cert.categoria}
              >
                <img 
                  src={cert.imagen} 
                  alt={cert.titulo} 
                  class="certificate-image"
                  loading="lazy"
                />
                <div class="certificate-content">
                  <h3 class="certificate-title">{cert.titulo}</h3>
                  <p class="certificate-description">{cert.descripcion}</p>
                  
                  <div class="certificate-dates">
                    <div class="date-item">
                      <span class="date-label">📅 Expedición:</span>
                      <span class="date-value">{cert.fechaExpedicion}</span>
                    </div>
                    <div class="date-item">
                      <span class="date-label">⏳ Vencimiento:</span>
                      <span class="date-value">{cert.fechaVencimiento}</span>
                    </div>
                  </div>
                </div>
              </a>
            ) : (
              <div 
                class="certificate-card"
                data-category={cert.categoria}
              >
                <img 
                  src={cert.imagen} 
                  alt={cert.titulo} 
                  class="certificate-image"
                  loading="lazy"
                />
                <div class="certificate-content">
                  <h3 class="certificate-title">{cert.titulo}</h3>
                  <p class="certificate-description">{cert.descripcion}</p>
                  
                  <div class="certificate-dates">
                    <div class="date-item">
                      <span class="date-label">📅 Expedición:</span>
                      <span class="date-value">{cert.fechaExpedicion}</span>
                    </div>
                    <div class="date-item">
                      <span class="date-label">⏳ Vencimiento:</span>
                      <span class="date-value">{cert.fechaVencimiento}</span>
                    </div>
                  </div>
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </section>

    <!-- Timeline Académico -->
    <section id="timeline" class="section-timeline">
      <div class="container-max">
        <h2 class="section-title gsap-title">Timeline Académico</h2>
        <div class="timeline gsap-timeline">
          <div class="timeline-item left">
            <div class="timeline-content">
              <h3 class="timeline-title">Técnico en Programación</h3>
              <p class="timeline-desc">Universidad Bancaria de México – Fundamentos sólidos en programación y desarrollo de software.</p>
            </div>
            <div class="timeline-date">2016-2019</div>
          </div>
          <div class="timeline-item right">
            <div class="timeline-content">
              <h3 class="timeline-title">Certificaciones en Bases de Datos</h3>
              <ul class="timeline-list">
                <li>SQL y Normalización</li>
                <li>MongoDB y NoSQL</li>
                <li>JPA / Hibernate</li>
              </ul>
            </div>
            <div class="timeline-date">2020-2022</div>
          </div>
          <div class="timeline-item left">
            <div class="timeline-content">
              <h3 class="timeline-title">Ingeniería en Sistemas Computacionales</h3>
              <p class="timeline-desc">Universidad Bancaria de México – Especialización en desarrollo full-stack, arquitectura de sistemas y gestión de proyectos.</p>
            </div>
            <div class="timeline-date">2021-2025</div>
          </div>
          <div class="timeline-item right">
            <div class="timeline-content">
              <h3 class="timeline-title">Certificaciones en Desarrollo Web y Arquitectura</h3>
              <ul class="timeline-list">
                <li>Java Full Stack</li>
                <li>JavaScript Avanzado</li>
                <li>Microservicios con Spring Boot</li>
                <li>APIs y Seguridad con JWT</li>
              </ul>
            </div>
            <div class="timeline-date">2022-2025</div>
          </div>
          <div class="timeline-item left">
            <div class="timeline-content">
              <h3 class="timeline-title">Certificaciones en Marketing Digital y Metodologías Ágiles</h3>
              <ul class="timeline-list">
                <li>Google Analytics</li>
                <li>SEO y Estrategias Digitales</li>
                <li>SCRUM Fundamentals</li>
                <li>Gestión de Proyectos Ágiles</li>
              </ul>
            </div>
            <div class="timeline-date">2020-2025</div>
          </div>
        </div>
      </div>
    </section>

    <section id="conocimientos" class="section-conocimientos">
      <div class="container-max-lg">
        <h2 class="section-title gsap-title">Conocimientos Técnicos</h2>
        <div class="knowledge-grid gsap-grid">
          <div class="knowledge-card">
            <h3 class="card-title">Lenguajes de Programación</h3>
            <p class="card-text">Java (Full Stack con Spring Boot), JavaScript (ES6+), Python, PHP, C++. Desarrollo orientado a objetos, algoritmos eficientes y optimización de rendimiento en entornos escalables.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Desarrollo Web Frontend</h3>
            <p class="card-text">HTML5, CSS3 (Flexbox/Grid), JavaScript/TypeScript, jQuery. Interfaces responsivas, accesibles y optimizadas para UX/UI con enfoque en rendimiento y SEO.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Frameworks y Librerías</h3>
            <p class="card-text">Angular (componentes, routing, JWT), React, Spring Boot (microservicios, Modulith), Node.js/Express, Bootstrap. Arquitecturas modulares y despliegues con Docker/Kubernetes.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Bases de Datos</h3>
            <p class="card-text">SQL (MySQL, PostgreSQL), NoSQL (MongoDB), SQLite, JPA/Hibernate. Diseño relacional, normalización, consultas avanzadas y gestión de datos en aplicaciones JavaFX.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Computación en la Nube</h3>
            <p class="card-text">AWS (servicios básicos y arquitectura), Google Cloud Platform, Azure. Despliegue escalable, seguridad y mejores prácticas en entornos cloud híbridos.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Arquitectura de Software</h3>
            <p class="card-text">Patrones SOLID, UML, diseño de sistemas distribuidos. Transición monolito a microservicios, escalabilidad y mantenibilidad en aplicaciones enterprise.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Inteligencia Artificial y ML</h3>
            <p class="card-text">Ingeniería de IA: Modelos de machine learning, deep learning, optimización de algoritmos y manejo de datos para soluciones en sectores reales.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Marketing Digital y Análisis</h3>
            <p class="card-text">Google Analytics (métricas, segmentación), SEO, campañas digitales. Estrategias data-driven para optimización de rendimiento y engagement.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Metodologías Ágiles</h3>
            <p class="card-text">Scrum (sprints, roles), Kanban (flujo visual, mejora continua). Gestión iterativa de proyectos con enfoque en entrega de valor y colaboración.</p>
          </div>
          <div class="knowledge-card">
            <h3 class="card-title">Herramientas de Productividad</h3>
            <p class="card-text">Notion (bases de datos, IA), Git, VS Code, IntelliJ. Flujos colaborativos, automatización y optimización de workflows en equipos remotos.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="aptitudes" class="section-aptitudes">
      <div class="container-max-lg">
        <h2 class="section-title gsap-title">Aptitudes Profesionales</h2>
        <div class="skills-columns gsap-skills">
          <ul class="skills-list">
            <li class="skill-item"><span class="bullet">▸</span> Liderazgo estratégico y motivación de equipos multidisciplinarios</li>
            <li class="skill-item"><span class="bullet">▸</span> Resolución analítica de problemas complejos con pensamiento crítico</li>
            <li class="skill-item"><span class="bullet">▸</span> Comunicación asertiva y persuasiva en entornos colaborativos</li>
            <li class="skill-item"><span class="bullet">▸</span> Adaptabilidad a tecnologías emergentes y cambios ágiles</li>
            <li class="skill-item"><span class="bullet">▸</span> Innovación en diseño de soluciones escalables y sostenibles</li>
          </ul>
          <ul class="skills-list">
            <li class="skill-item"><span class="bullet">▸</span> Planificación y ejecución de proyectos con metodologías híbridas</li>
            <li class="skill-item"><span class="bullet">▸</span> Gestión eficiente de recursos y optimización de procesos</li>
            <li class="skill-item"><span class="bullet">▸</span> Análisis de datos avanzado para toma de decisiones informadas</li>
            <li class="skill-item"><span class="bullet">▸</span> Aprendizaje autónomo y continuo en entornos dinámicos</li>
            <li class="skill-item"><span class="bullet">▸</span> Empatía y fomentación de culturas inclusivas en equipos</li>
          </ul>
          <ul class="skills-list">
            <li class="skill-item"><span class="bullet">▸</span> Resiliencia bajo presión con enfoque en resultados medibles</li>
            <li class="skill-item"><span class="bullet">▸</span> Creatividad aplicada a UX/UI y estrategias digitales</li>
            <li class="skill-item"><span class="bullet">▸</span> Ética profesional en seguridad y privacidad de datos</li>
            <li class="skill-item"><span class="bullet">▸</span> Colaboración remota con herramientas globales</li>
            <li class="skill-item"><span class="bullet">▸</span> Orientación a cliente con métricas de satisfacción</li>
          </ul>
        </div>
      </div>
    </section>

   <section id="tecnologias" class="section-tecnologias">
    <div class="container-max-lg">
      <h2 class="section-title gsap-title">Tecnologías que Utilizo</h2>
      <div class="technologies-grid gsap-grid">
        <div class="tech-card">
          <h3 class="card-title">Backend</h3>
          <ul class="tech-list">
            <li>Java (Spring Boot)</li>
            <li>Node.js (Express)</li>
            <li>PHP (Laravel)</li>
            <li>Python (Django/Flask)</li>
            <li>Ruby (Rails)</li>
            <li>Go (Gin)</li>
            <li>.NET Core</li>
            <li>C#</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Frontend</h3>
          <ul class="tech-list">
            <li>Angular</li>
            <li>React (Next.js)</li>
            <li>JavaScript/TypeScript</li>
            <li>jQuery</li>
            <li>Vue.js (Nuxt.js)</li>
            <li>Svelte</li>
            <li>HTML5/CSS3 (Sass)</li>
            <li>Tailwind CSS/Bootstrap</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Bases de Datos</h3>
          <ul class="tech-list">
            <li>MySQL/PostgreSQL</li>
            <li>MongoDB</li>
            <li>SQLite</li>
            <li>Hibernate/JPA</li>
            <li>Redis</li>
            <li>Cassandra</li>
            <li>Oracle</li>
            <li>Elasticsearch</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Cloud & DevOps</h3>
          <ul class="tech-list">
            <li>AWS (EC2, S3)</li>
            <li>Google Cloud (GCP)</li>
            <li>Azure</li>
            <li>Docker</li>
            <li>Kubernetes</li>
            <li>Terraform</li>
            <li>Jenkins (CI/CD)</li>
            <li>Ansible</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Herramientas</h3>
          <ul class="tech-list">
            <li>Git (GitHub/GitLab)</li>
            <li>VS Code/IntelliJ</li>
            <li>Notion</li>
            <li>Google Analytics</li>
            <li>Postman</li>
            <li>Jira/Trello</li>
            <li>Figma</li>
            <li>Docker Compose</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">IA & Otros</h3>
          <ul class="tech-list">
            <li>Machine Learning (TensorFlow)</li>
            <li>Deep Learning (PyTorch)</li>
            <li>UML</li>
            <li>JWT/Seguridad (OAuth)</li>
            <li>REST/GraphQL</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Metodologías</h3>
          <ul class="tech-list">
            <li>Scrum</li>
            <li>Kanban</li>
            <li>Agile</li>
            <li>DevOps</li>
            <li>Lean</li>
            <li>Waterfall</li>
            <li>TDD/BDD</li>
          </ul>
        </div>
        <div class="tech-card">
          <h3 class="card-title">Testing</h3>
          <ul class="tech-list">
            <li>JUnit</li>
            <li>Selenium</li>
            <li>Jest</li>
            <li>Mocha</li>
            <li>Cypress</li>
            <li>Postman</li>
          </ul>
        </div>
      </div>
    </div>
    </section>

    <section id="idiomas" class="section-idiomas">
      <div class="container-max-md">
        <h2 class="section-title gsap-title">Inglés</h2>
        <div class="progress-container gsap-progress">
          <div class="progress-item">
            <div class="progress-header">
              <span>Vocabulario básico</span>
              <span>75%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" data-width="75%"></div>
            </div>
          </div>
          <div class="progress-item">
            <div class="progress-header">
              <span>Pronunciación</span>
              <span>90%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" data-width="90%"></div>
            </div>
          </div>
          <div class="progress-item">
            <div class="progress-header">
              <span>Gramática básica</span>
              <span>70%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" data-width="70%"></div>
            </div>
          </div>
          <div class="progress-item">
            <div class="progress-header">
              <span>Comprensión auditiva</span>
              <span>85%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" data-width="85%"></div>
            </div>
          </div>
          <div class="progress-item">
            <div class="progress-header">
              <span>Escritura y lectura</span>
              <span>90%</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" data-width="90%"></div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
  import '../scripts/habilidades.js';
  import '../data/certificaciones.js';
  import { gsap } from 'gsap';
  
  // ========== FLOATING NAVIGATION ==========
  const floatingNav = document.getElementById('floatingNav');
  const floatingNavToggle = document.getElementById('floatingNavToggle');

  floatingNavToggle?.addEventListener('click', () => {
    floatingNav?.classList.toggle('active');
  });

  // Close floating nav when clicking outside
  document.addEventListener('click', (e) => {
    if (floatingNav && !floatingNav.contains(e.target as Node)) {
      floatingNav.classList.remove('active');
    }
  });

  // Close floating nav when clicking on a link
  document.querySelectorAll('.floating-nav-item').forEach(item => {
    item.addEventListener('click', () => {
      floatingNav?.classList.remove('active');
    });
  });

  // Smooth scroll for internal links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(this: HTMLElement, e: Event) {
      e.preventDefault();
      const target = document.querySelector((this as HTMLAnchorElement).getAttribute('href') || '');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
  
  // ========== GENERACIÓN DE ELEMENTOS DINÁMICOS ==========
  
  // Código binario (Matrix)
  const binaryContainer = document.getElementById('binaryContainer');
  const binaryStrings = ['01001000', '01100101', '01101100', '01101100', '01101111', '01010111', '01101111', '01110010', '01101100', '01100100'];
  
  for (let i = 0; i < 30; i++) {
    const binary = document.createElement('div');
    binary.className = 'binary-rain';
    binary.textContent = binaryStrings[Math.floor(Math.random() * binaryStrings.length)].repeat(10);
    binary.style.left = `${Math.random() * 100}%`;
    binary.style.animationDuration = `${Math.random() * 5 + 8}s`;
    binary.style.animationDelay = `${Math.random() * 5}s`;
    binaryContainer?.appendChild(binary);
  }
  
  // Circuitos
  const circuitBoard = document.getElementById('circuitBoard');
  for (let i = 0; i < 15; i++) {
    const line = document.createElement('div');
    line.className = 'circuit-line';
    line.style.top = `${Math.random() * 100}%`;
    line.style.left = `${Math.random() * 80}%`;
    line.style.width = `${Math.random() * 200 + 100}px`;
    line.style.animationDelay = `${Math.random() * 4}s`;
    circuitBoard?.appendChild(line);
    
    // Agregar nodos
    const node = document.createElement('div');
    node.className = 'circuit-node';
    node.style.left = `${Math.random() * 80}%`;
    node.style.animationDelay = `${Math.random() * 2}s`;
    line.appendChild(node);
  }
  
  // Partículas de datos
  const dataContainer = document.getElementById('dataParticlesContainer');
  for (let i = 0; i < 25; i++) {
    const particle = document.createElement('div');
    particle.className = 'data-particle';
    particle.style.top = `${Math.random() * 100}%`;
    particle.style.left = `${Math.random() * 100}%`;
    particle.style.animationDuration = `${Math.random() * 5 + 5}s`;
    particle.style.animationDelay = `${Math.random() * 8}s`;
    dataContainer?.appendChild(particle);
  }
  
  // Hexágonos
  const hexContainer = document.getElementById('hexContainer');
  for (let i = 0; i < 12; i++) {
    const hexPattern = document.createElement('div');
    hexPattern.className = 'hex-pattern';
    hexPattern.style.top = `${Math.random() * 100}%`;
    hexPattern.style.left = `${Math.random() * 100}%`;
    hexPattern.style.animationDuration = `${Math.random() * 15 + 15}s`;
    hexPattern.style.animationDelay = `${Math.random() * 10}s`;
    
    const hexagon = document.createElement('div');
    hexagon.className = 'hexagon';
    hexPattern.appendChild(hexagon);
    
    hexContainer?.appendChild(hexPattern);
  }
  
  // ========== ANIMACIONES GSAP ==========
  
  // Hologramas
  gsap.to('.hologram', {
    rotationY: 360,
    rotationX: 60,
    duration: 10,
    repeat: -1,
    ease: 'linear'
  });
  
  // Íconos tecnológicos
  gsap.utils.toArray('.tech-icon').forEach((icon: any) => {
    gsap.to(icon, {
      y: -30,
      rotation: 360,
      duration: 15,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  });
  
  // Terminales de código
  gsap.to('.code-terminal', {
    y: -20,
    duration: 8,
    repeat: -1,
    yoyo: true,
    ease: 'sine.inOut'
  });
  
  // Parallax con mouse
  document.addEventListener('mousemove', (e) => {
    const mouseX = e.clientX / window.innerWidth;
    const mouseY = e.clientY / window.innerHeight;
    
    gsap.to('.circuit-line', {
      x: mouseX * 20,
      y: mouseY * 20,
      duration: 2
    });
    
    gsap.to('.hologram', {
      x: mouseX * -30,
      y: mouseY * -30,
      duration: 2.5
    });
    
    gsap.to('.tech-icon', {
      x: mouseX * 15,
      y: mouseY * 15,
      duration: 3
    });
  });
</script>
</Layout>